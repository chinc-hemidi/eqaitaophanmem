{
  "name": "emotion-checkin-system",
  "version": "1.0.0",
  "private": true,
  "description": "Emotion check-in system with NestJS, Angular and MySQL",
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "build:gui": "npm --prefix gui run build",
    "copy:gui": "powershell -NoProfile -Command \"if (Test-Path public/gui) { Remove-Item -Recurse -Force public/gui/* -ErrorAction SilentlyContinue }; New-Item -ItemType Directory -Force -Path public/gui | Out-Null; Copy-Item -Path gui/dist/gui/browser/* -Destination public/gui -Recurse -Force\"",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeders/seed.ts",
    "seed:prod": "node dist/database/seeders/seed.js",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.16",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.16",
    "@nestjs/platform-express": "^10.4.16",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.13.3",
    "mysql2": "^3.15.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.16",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.28",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
